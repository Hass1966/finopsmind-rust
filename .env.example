# FinOpsMind Environment Variables
# Copy this file to .env and fill in the values.

# ---------- Database ----------
# Full PostgreSQL connection string (overrides host/port/user/password/name in config.yaml)
DATABASE_URL=postgres://finopsmind:CHANGE_ME@localhost:5432/finopsmind

# ---------- Redis ----------
# Full Redis connection string
REDIS_URL=redis://localhost:6379

# ---------- Authentication ----------
# Secret key used to sign JWT tokens (min 32 characters recommended)
AUTH__JWT_SECRET=CHANGE_ME_generate_a_strong_random_secret

# Master encryption key for encrypting cloud provider credentials at rest (exactly 32 bytes)
AUTH__ENCRYPTION_KEY=CHANGE_ME_exactly_32_bytes_long!

# ---------- LLM / AI ----------
# LLM provider: "anthropic" or "ollama"
LLM__PROVIDER=ollama

# LLM API endpoint URL
LLM__URL=http://localhost:11434/api/chat

# Model name to use
LLM__MODEL=llama3.1:8b

# API key (required for anthropic, unused for ollama)
LLM__API_KEY=

# ---------- Server ----------
# Host address to bind to
SERVER__HOST=0.0.0.0

# Port to listen on
SERVER__PORT=8080
